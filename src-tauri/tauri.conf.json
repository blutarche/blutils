{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "blutils",
  "version": "0.1.0",
  "identifier": "dev.blutarche.blutils",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build:client",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'"
    },
    "windows": [
      {
        "title": "blutils",
        "width": 1200,
        "height": 800,
        "minWidth": 680,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "transparent": false,
        "trafficLightPosition": { "x": 14, "y": 25 }
      }
    ],
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "frameworks": []
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBRjUyRDVCRjVGQTgwQQpSV1FLcUYrLzFWS3ZEcGVxMndOamhwWnZJdUpmK1VsWTFiNmVmM1VUWUpMdmNoMitlN0t1cWlIMQo=",
      "endpoints": [
        "https://github.com/blutarche/blutils/releases/latest/download/latest.json"
      ]
    }
  }
}
