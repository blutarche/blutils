{
  "name": "blutils",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:client && pnpm build:server && pnpm build:prerender",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist-server",
    "build:prerender": "node scripts/prerender.mjs",
    "preview": "node scripts/preview-static.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "subset:fonts": "node scripts/subset-fonts.mjs",
    "render:og": "node scripts/render-og.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "dompurify": "^3.4.5",
    "lucide-preact": "^1.16.0",
    "marked": "^18.0.4",
    "preact": "^10.25.0",
    "prismjs": "^1.30.0",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.5",
    "@types/prismjs": "^1.26.6",
    "preact-render-to-string": "^6.7.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.9",
    "wawoff2": "^2.0.1"
  }
}
